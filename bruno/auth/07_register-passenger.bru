meta {
  name: Register Passenger
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "{{passengerEmail}}",
    "password": "{{passengerPassword}}",
    "displayName": "Marie Pasager",
    "phoneDialCode": "+33",
    "phoneNumber": "0698765432"
  }
}

assert {
  res.status: in [201, 409]
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("passengerToken", res.body.accessToken);
  }
}
