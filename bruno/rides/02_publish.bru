meta {
  name: Publish Ride
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/rides
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "from": "Paris",
    "to": "Lyon",
    "departureTime": "2026-04-01T08:00:00Z",
    "totalSeats": 3
  }
}

assert {
  res.status: eq 201
  res.body.rideId: isDefined
  res.body.status: eq SCHEDULED
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("rideId", res.body.rideId);
  }
}
