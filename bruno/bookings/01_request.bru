meta {
  name: Request Booking
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/rides/{{rideId}}/booking-requests
  body: none
  auth: bearer
}

auth:bearer {
  token: {{passengerToken}}
}

assert {
  res.status: eq 201
  res.body.bookingRequestId: isDefined
  res.body.status: eq REQUESTED
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("bookingRequestId", res.body.bookingRequestId);
  }
}
